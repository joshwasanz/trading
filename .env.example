# Copy this file to `.env` for local runtime testing.
# Keep the real value out of source control.

DATA_PROVIDER=twelve_data
TWELVE_DATA_API_KEY=91b798d6fbc54676bf548a326c77449a
TWELVE_DATA_REST_BASE_URL=https://api.twelvedata.com

# Historical candles use Twelve Data where supported.
# Validation currently supports forex 1m/3m and index 1m.
# Set STRICT_REALTIME=true to fail instead of silently falling back to synthetic.
# STRICT_REALTIME=true
# TWELVE_DATA_LIVE_POLL_INTERVAL_MS=15000
# Set VITE_FREE_TIER_VALIDATION_MODE=true to force a single EURUSD/USDJPY forex chart during free-tier validation.
# VITE_FREE_TIER_VALIDATION_MODE=true
# Set VITE_STARTUP_DIAGNOSTICS_MODE=minimal to boot a static renderer for Tauri/WebView2 crash isolation.
# VITE_STARTUP_DIAGNOSTICS_MODE=minimal
TWELVE_DATA_SYMBOL_EURUSD=EUR/USD
TWELVE_DATA_SYMBOL_USDJPY=USD/JPY
TWELVE_DATA_SYMBOL_SPX=SPX
TWELVE_DATA_SYMBOL_NDX=NDX

# Staged symbols for later expansion.
# TWELVE_DATA_SYMBOL_GBPUSD=GBP/USD
# TWELVE_DATA_SYMBOL_USDCHF=USD/CHF
# TWELVE_DATA_SYMBOL_AUDUSD=AUD/USD
# TWELVE_DATA_SYMBOL_USDCAD=USD/CAD
# TWELVE_DATA_SYMBOL_DJI=DJI
